# ============================================
# LMS Backend Configuration (Production Template)
# ============================================
# Copy this to .env and fill in real values

APP_NAME="Happy Baby"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=CHANGE-ME-USE-openssl-rand-hex-64
API_V1_PREFIX=/api/v1

# Database — use strong password, disable external access
DATABASE_URL=postgresql+asyncpg://lms_user:STRONG_PASSWORD_HERE@db:5432/lms_db

# Redis
REDIS_URL=redis://redis:6379/0

# JWT — use strong secrets
JWT_SECRET_KEY=CHANGE-ME-USE-openssl-rand-hex-64
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Backblaze B2
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_KEY_ID=YOUR_B2_KEY_ID
B2_APP_KEY=YOUR_B2_APP_KEY
B2_BUCKET_NAME=your-bucket-name
B2_REGION=us-west-004

# Video Security
VIDEO_SIGNING_SECRET=CHANGE-ME-USE-openssl-rand-hex-32

# SMS (Phase 2)
SMS_API_KEY=mock
SMS_SENDER_ID=HappyBaby

# CORS — only allow your frontend domain
CORS_ORIGINS=["https://your-domain.com"]

# Superadmin — change after first login!
SUPERADMIN_PHONE=01700000000
SUPERADMIN_PASSWORD=CHANGE-ME-STRONG-PASSWORD
