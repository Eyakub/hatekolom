# ============================================
# LMS Backend Configuration (PRODUCTION)
# ============================================
# Copy this to .env.prod and fill all values
# NEVER commit .env.prod to version control!
# ============================================

APP_NAME="Hate Kolom"
APP_VERSION="1.0.0"
DEBUG=false
SECRET_KEY=  # Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
API_V1_PREFIX=/api/v1
# Native deployment (localhost)
DATABASE_URL=postgresql+asyncpg://hatekolom_user:YOUR_STRONG_PASSWORD@localhost:5432/hatekolom_db
DATABASE_URL_SYNC=postgresql://hatekolom_user:YOUR_STRONG_PASSWORD@localhost:5432/hatekolom_db

# Redis — no password needed if localhost-only (see server-setup.sh)
REDIS_URL=redis://localhost:6379/0

JWT_SECRET_KEY=  # Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Backblaze B2 Storage
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET_NAME=
B2_REGION=us-west-004

VIDEO_SIGNING_SECRET=  # Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"

# CORS — your production domain
CORS_ORIGINS='["https://hatekolom.org"]'

# Super Admin (created on first boot)
SUPERADMIN_PHONE=
SUPERADMIN_PASSWORD=  # Use a strong password!

# SSLCommerz (LIVE credentials)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWORD=
SSLCOMMERZ_SANDBOX=false
SSLCOMMERZ_SUCCESS_URL=https://hatekolom.org/payment/success
SSLCOMMERZ_FAIL_URL=https://hatekolom.org/payment/fail
SSLCOMMERZ_CANCEL_URL=https://hatekolom.org/payment/cancel
SSLCOMMERZ_IPN_URL=https://hatekolom.org/api/v1/payments/sslcommerz/ipn

# SMTP Email (Gmail App Password or AWS SES)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_NAME="Hate Kolom"
SMTP_FROM_EMAIL=

# SMS (BulkSMSBD — LIVE)
SMS_API_KEY=
SMS_API_URL=https://bulksmsbd.net/api/smsapi
SMS_SENDER_ID=HateKolom
SMS_MOCK=false
